                    nota = float(input(f"Joven de los jovenes deme la nota {i+1} de {self.nombre}: "))
                    if self.nota_valida(nota):
                        self.notas.append(nota)
                        break
                    else:
                        print("Esa nota no es valida joven, debe ser  entre 0.0 a 5.0")
               
    
    def calcular_definitiva(self):
